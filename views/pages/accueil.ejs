<%- include('../partials/header') %>

<div class="hero-section">
    <div class="hero-content">
        <h1>Bienvenue à la Bibliothèque</h1>
        <p>Découvrez notre collection de livres et gérez votre bibliothèque facilement</p>
        <div class="hero-buttons">
            <a href="/livres" class="btn btn-primary">
                <i class="fas fa-book"></i> Voir tous les livres
            </a>
            <a href="/auteurs" class="btn btn-secondary">
                <i class="fas fa-users"></i> Voir les auteurs
            </a>
        </div>
    </div>
</div>

<div class="features-section">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-book"></i>
                </div>
                <div class="feature-content">
                    <h3>Collection</h3>
                    <p>Explorez notre catalogue</p>
                </div>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="feature-content">
                    <h3>Auteurs</h3>
                    <p>Découvrez nos auteurs</p>
                </div>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-search"></i>
                </div>
                <div class="feature-content">
                    <h3>Recherche</h3>
                    <p>Trouvez votre livre</p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        margin: 20px 0 40px 0;
        padding: 60px 40px;
        text-align: center;
        color: white;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }
    
    .hero-content h1 {
        font-size: 2.5rem;
        margin-bottom: 16px;
        font-weight: 700;
    }
    
    .hero-content p {
        font-size: 1.1rem;
        margin-bottom: 32px;
        opacity: 0.95;
    }
    
    .hero-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }
    
    .btn-primary {
        background: white;
        color: #667eea;
    }
    
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }
    
    .btn-secondary {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        backdrop-filter: blur(10px);
    }
    
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateY(-2px);
    }
    
    .features-section {
        padding: 20px 0 60px 0;
    }
    
    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
    }
    
    .feature-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        cursor: pointer;
    }
    
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }
    
    .feature-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
    }
    
    .feature-icon i {
        font-size: 28px;
        color: white;
    }
    
    .feature-content h3 {
        font-size: 1.25rem;
        color: #2d3748;
        margin-bottom: 8px;
    }
    
    .feature-content p {
        color: #718096;
        font-size: 0.9rem;
    }
    
    @media (max-width: 768px) {
        .hero-section {
            padding: 40px 20px;
        }
        
        .hero-content h1 {
            font-size: 1.8rem;
        }
        
        .hero-content p {
            font-size: 1rem;
        }
        
        .btn {
            padding: 10px 20px;
            font-size: 0.85rem;
        }
        
        .features-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        
        .feature-card {
            padding: 20px;
        }
    }
</style>